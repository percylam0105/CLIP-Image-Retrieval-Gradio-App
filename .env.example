# CLIP Model
MODEL_ID=anhquanlam/clip-finetuned-deepfashion

# Qdrant
QDRANT_MODE=remote
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=fashion_images

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=fashion-images
MINIO_SECURE=false

# Legacy data paths (for migration)
LEGACY_IMAGES_PATH=./DeepFashion/images
LEGACY_INDEX_PATH=./DeepFashion/embed_data
CAPTIONS_PATH=./DeepFashion/captions.json

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
